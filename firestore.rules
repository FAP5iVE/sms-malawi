rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isAuth() && role() == "admin";
    }
    function isStaff() {
      return isAuth() && role() in [
        "admin","high_rank","finance","library",
        "lower_rank","academic","hr","exam_officer"
      ];
    }
    function isTeacher() {
      return isAuth() && role() in ["admin","high_rank","academic","exam_officer"];
    }
    function isStudent() {
      return isAuth() && role() == "student";
    }
    function isHighRankOrAdmin() {
      return isAuth() && role() in ["admin","high_rank"];
    }

    // ── Attendance ──────────────────────────────────────────
    // Path: attendance/{classId}/records/{date}
    match /attendance/{classId}/records/{date} {
      allow read: if isStaff() || isStudent();
      // Only teachers and admin can mark attendance
      allow write: if isTeacher() || isHighRankOrAdmin();
    }

    // ── Announcements ───────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if isAuth() &&
        (resource.data.targetRoles.hasAny([role()]) ||
         resource.data.targetAll == true);

      // Only staff can create, admin/high rank can publish
      allow create: if isStaff();
      allow update: if isHighRankOrAdmin() ||
        (isStaff() && resource.data.createdByUid == request.auth.uid
         && resource.data.status == "DRAFT");
      allow delete: if isAdmin();
    }

    // ── Notifications ───────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      // Users can only read/update their own notifications
      allow read, update: if isAuth() && request.auth.uid == userId;
      allow create: if isStaff(); // staff create notifications for others
      allow delete: if isAuth() && request.auth.uid == userId;
    }

    // ── Calendar Events ─────────────────────────────────────
    match /calendar_events/{eventId} {
      allow read:   if isAuth();
      allow create: if isStaff();
      allow update, delete: if isHighRankOrAdmin() ||
        (isStaff() && resource.data.createdByUid == request.auth.uid);
    }

    // ── Deny everything else ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}