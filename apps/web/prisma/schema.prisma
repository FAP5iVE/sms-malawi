generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ─── STUDENTS ────────────────────────────────────────────
model Student {
  id               String   @id @default(cuid())
  registrationNo   String   @unique          // auto-generated e.g. SMS-2025-0001
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  sex              Sex
  nationality      String   @default("Malawian")
  district         String
  village          String?
  address          String?
  phone            String?
  guardianName     String
  guardianPhone    String
  guardianRelation String
  photoKey         String? 
  status           StudentStatus @default(ACTIVE)
  classId          String?
  class            Class?        @relation(fields: [classId], references: [id])
  borrowings       Borrowing[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([classId])
  @@index([status])
  @@map("students")
}

enum StudentStatus {
  ACTIVE
  AWAITING_MANEB_RESULTS
  GRADUATED
  ARCHIVED
}

enum Sex {
  MALE
  FEMALE
}

// ─── CLASSES ─────────────────────────────────────────────
model Class {
  id          String    @id @default(cuid())
  name        String                       // "Form 1A", "Form 2B", etc.
  form        Int                          // 1, 2, 3, or 4
  stream      String?                      // "A", "B", "Science", "Arts"
  teacherId   String?                      // class teacher Firebase UID
  room        String?
  academicYear String                      // "2025/2026"
  students    Student[]
  assignments Assignment[]
  labBookings LabBooking[]
  timetable   TimetableSlot[]
  exams       Exam[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([form])
  @@index([academicYear])
  @@map("classes")
}

// ─── ASSIGNMENTS ─────────────────────────────────────────
model Assignment {
  id          String    @id @default(cuid())
  title       String
  description String?
  subject     String
  classId     String
  class       Class     @relation(fields: [classId], references: [id])
  dueDate     DateTime
  createdByUid String                     // teacher Firebase UID
  submissions AssignmentSubmission[]
  createdAt   DateTime  @default(now())

  @@index([classId])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String    @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  fileKey      String?   // R2 object key for uploaded file
  submittedAt  DateTime  @default(now())
  status       SubmissionStatus @default(SUBMITTED)

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  MISSING
}

// ─── LAB BOOKINGS ─────────────────────────────────────────
model LabBooking {
  id           String    @id @default(cuid())
  classId      String
  class        Class     @relation(fields: [classId], references: [id])
  bookedByUid  String    // teacher Firebase UID
  labName      String    @default("Science Lab")
  date         DateTime
  periodStart  String    // "08:00"
  periodEnd    String    // "09:00"
  purpose      String?
  createdAt    DateTime  @default(now())

  @@index([date])
  @@map("lab_bookings")
}

// ─── APPLICATIONS ────────────────────────────────────────
model Application {
  id               String            @id @default(cuid())
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  sex              Sex
  nationality      String
  district         String
  village          String?
  guardianName     String
  guardianPhone    String
  guardianRelation String
  applyingForForm  Int               // 1–4
  status           ApplicationStatus @default(PENDING)
  reviewedByUid    String?
  reviewedAt       DateTime?
  notes            String?
  convertedStudentId String?         // set when converted to Student record
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DENIED
  AWAITING_ADMISSION
  ADMITTED
}

// ─── TIMETABLE ───────────────────────────────────────────
model TimetableSlot {
  id          String    @id @default(cuid())
  classId     String
  class       Class     @relation(fields: [classId], references: [id])
  day         Weekday
  periodStart String    // "07:30"
  periodEnd   String    // "08:30"
  subject     String
  teacherUid  String
  room        String?
  type        TimetableType @default(REGULAR)
  academicYear String
  term        Int       // 1, 2, or 3
  approvedAt  DateTime?
  approvedByUid String?

  @@index([classId, day])
  @@index([academicYear, term])
  @@map("timetable_slots")
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
enum TimetableType {
  REGULAR
  EXAM
  MANEB
  LAB
}

// ─── AUDIT LOG ───────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  action     String                         // "student.create", "student.archive"
  entityType String                         // "Student", "Application"
  entityId   String
  actorUid   String
  actorRole  String
  metadata   Json?                          // before/after values
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUid])
  @@map("audit_logs")
}


// ─── FEE STRUCTURE ───────────────────────────────────────
model FeeStructure {
  id           String   @id @default(cuid())
  name         String                        // "Tuition", "Boarding", "Exam", "Uniform", "Library", "Transport"
  amount       Decimal  @db.Decimal(12, 2)   // MWK amount
  classId      String?                       // null = applies to all classes
  academicYear String
  term         Int?                          // null = applies to all terms
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([academicYear, classId])
  @@map("fee_structures")
}

// ─── STUDENT INVOICE (per term per student) ───────────────
model Invoice {
  id              String          @id @default(cuid())
  studentId       String
  academicYear    String
  term            Int
  subtotal        Decimal         @db.Decimal(12, 2)
  discount        Decimal         @db.Decimal(12, 2) @default(0)
  latePenalty     Decimal         @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal         @db.Decimal(12, 2)
  paidAmount      Decimal         @db.Decimal(12, 2) @default(0)
  balance         Decimal         @db.Decimal(12, 2)   // totalAmount - paidAmount
  status          InvoiceStatus   @default(UNPAID)
  dueDate         DateTime
  scholarshipId   String?
  payments        Payment[]
  notes           InvoiceNote[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([studentId, academicYear, term])   // one invoice per student per term
  @@index([studentId])
  @@index([status])
  @@index([academicYear, term])
  @@map("invoices")
}

enum InvoiceStatus {
    UNPAID
    PARTIAL
    PAID 
    OVERDUE
     }

// ─── PAYMENT RECORD ──────────────────────────────────────
model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  reference    String?       // bank ref, mobile money transaction ID
  receiptKey   String?       // R2 object key for generated PDF receipt
  recordedByUid String
  notes        String?
  paidAt       DateTime      @default(now())

  @@index([invoiceId])
  @@map("payments")
}

enum PaymentMethod {
   CASH  
   BANK_TRANSFER  
   MOBILE_MONEY  
   CHEQUE 
   }

// ─── INVOICE NOTES (sticky notes on transactions) ────────
model InvoiceNote {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  body      String
  authorUid String
  createdAt DateTime @default(now())

  @@map("invoice_notes")
}

// ─── EXPENSE ─────────────────────────────────────────────
model Expense {
  id           String          @id @default(cuid())
  category     ExpenseCategory
  description  String
  amount       Decimal         @db.Decimal(12, 2)
  receiptKey   String?         // R2 object key for scanned receipt
  academicYear String
  term         Int
  approvedByUid String?
  approvedAt   DateTime?
  status       ExpenseStatus   @default(PENDING)
  recordedByUid String
  incurredAt   DateTime
  createdAt    DateTime        @default(now())

  @@index([academicYear, term])
  @@index([category])
  @@map("expenses")
}

enum ExpenseCategory { 
  SALARIES  
  UTILITIES  
  MAINTENANCE  
  PROCUREMENT  
  LIBRARY  
  TRANSPORT  
  MISCELLANEOUS 
  }

enum ExpenseStatus  { 
  PENDING  
  APPROVED  
  REJECTED 
  }

// ─── PAYROLL ─────────────────────────────────────────────
model PayrollRun {
  id           String          @id @default(cuid())
  month        Int             // 1–12
  year         Int
  status       PayrollStatus   @default(PROCESSING)
  totalGross   Decimal         @db.Decimal(12, 2)
  totalNet     Decimal         @db.Decimal(12, 2)
  runByUid     String
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  payslips     Payslip[]

  @@unique([month, year])
  @@map("payroll_runs")
}

enum PayrollStatus { 
  PROCESSING  
  COMPLETED  
  FAILED 
  }

model Payslip {
  id            String     @id @default(cuid())
  payrollRunId  String
  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id])
  staffUid      String
  staffName     String
  grossSalary   Decimal    @db.Decimal(12, 2)
  paye          Decimal    @db.Decimal(12, 2)  // income tax
  pension       Decimal    @db.Decimal(12, 2)
  loanDeduction Decimal    @db.Decimal(12, 2) @default(0)
  netSalary     Decimal    @db.Decimal(12, 2)
  payslipKey    String?    // R2 object key for PDF payslip
  createdAt     DateTime   @default(now())

  @@index([staffUid])
  @@index([payrollRunId])
  @@map("payslips")
}

// ─── SALARY STRUCTURE ────────────────────────────────────
model SalaryStructure {
  id           String   @id @default(cuid())
  staffUid     String   @unique
  baseSalary   Decimal  @db.Decimal(12, 2)
  allowances   Decimal  @db.Decimal(12, 2) @default(0)
  loanBalance  Decimal  @db.Decimal(12, 2) @default(0)
  monthlyLoanDeduction Decimal @db.Decimal(12, 2) @default(0)
  updatedAt    DateTime @updatedAt

  @@map("salary_structures")
}

// ─── BUDGET ──────────────────────────────────────────────
model Budget {
  id           String   @id @default(cuid())
  academicYear String
  term         Int?     // null = annual budget
  department   String
  category     String
  description  String?
  allocated    Decimal  @db.Decimal(12, 2)
  spent        Decimal  @db.Decimal(12, 2) @default(0)
  createdByUid String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([academicYear])
  @@map("budgets")
}

// ─── SCHOLARSHIP / BURSARY ───────────────────────────────
model Scholarship {
  id           String           @id @default(cuid())
  name         String
  studentId    String
  discountType DiscountType
  value        Decimal          @db.Decimal(12, 2)  // % or fixed MWK amount
  academicYear String
  isActive     Boolean          @default(true)
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([studentId])
  @@map("scholarships")
}

enum DiscountType { 
  PERCENTAGE  
  FIXED_AMOUNT 
  }

// ─── INSTALLMENT PLAN ────────────────────────────────────
model InstallmentPlan {
  id           String              @id @default(cuid())
  invoiceId    String              @unique           // one plan per invoice
  totalAmount  Decimal             @db.Decimal(12, 2)
  installments Installment[]
  createdByUid String
  createdAt    DateTime            @default(now())

  @@map("installment_plans")
}

model Installment {
  id        String          @id @default(cuid())
  planId    String
  plan      InstallmentPlan @relation(fields: [planId], references: [id])
  dueDate   DateTime
  amount    Decimal         @db.Decimal(12, 2)
  paidAt    DateTime?
  status    InstallmentStatus @default(PENDING)

  @@index([planId])
  @@map("installments")
}

enum InstallmentStatus { 
  PENDING  
  PAID  
  OVERDUE 
  }

// ─── LIBRARY FINE (bridge between Library and Finance) ────
model LibraryFine {
  id              String          @id @default(cuid())
  studentId       String
  bookTitle       String
  firestoreDocId  String          @unique            // Firestore doc ID in library collection
  amount          Decimal         @db.Decimal(10, 2)
  reason          String
  status          FineStatus      @default(PENDING)
  markedByUid     String          // librarian who raised the fine
  paidAt          DateTime?
  clearedByUid    String?         // finance staff who marked it paid
  createdAt       DateTime        @default(now())

  @@index([studentId])
  @@index([status])
  @@map("library_fines")
}

enum FineStatus { 
  PENDING  
  PAID 
  WAIVED 
  }

  // ─── EXAMS ───────────────────────────────────────────────

model Exam {
  id            String     @id @default(cuid())
  type          ExamType
  subject       String
  classId       String
  class         Class      @relation(fields: [classId], references: [id])
  title         String
  date          DateTime
  timeStart     String
  timeEnd       String
  venue         String
  maxMark       Decimal    @db.Decimal(6,2) @default(100)
  weightPercent Decimal    @db.Decimal(5,2) @default(100)
  academicYear  String
  term          Int
  status        ExamStatus @default(SCHEDULED)
  createdByUid  String
  marks         ExamMark[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([classId, term])
  @@index([academicYear, term])
  @@map("exams")
}

enum ExamType {
  WEEKLY_TEST
  ASSIGNMENT
  QUIZ
  MIDTERM
  END_TERM
  MANEB_JCE
  MANEB_MSCE
}

enum ExamStatus {
  SCHEDULED
  IN_PROGRESS
  MARKS_PENDING
  MARKS_DRAFT
  MARKS_FINAL
  RESULTS_APPROVED
  RESULTS_RELEASED
}

model ExamMark {
  id           String    @id @default(cuid())
  examId       String
  exam         Exam      @relation(fields: [examId], references: [id])
  studentId    String
  mark         Decimal?  @db.Decimal(6,2)
  absent       Boolean   @default(false)
  comment      String?
  enteredByUid String
  isDraft      Boolean   @default(true)
  finalizedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("exam_marks")
}

model TermResult {
  id             String   @id @default(cuid())
  studentId      String
  classId        String
  academicYear   String
  term           Int
  totalMark      Decimal  @db.Decimal(6,2)
  average        Decimal  @db.Decimal(5,2)
  grade          String
  position       Int?
  passStatus     Boolean
  subjectResults Json
  attendanceDays Int      @default(0)
  absentDays     Int      @default(0)
  teacherComment String?
  headComment    String?
  reportCardKey  String?
  releasedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, academicYear, term])
  @@index([classId, academicYear, term])
  @@map("term_results")
}

model AnnualResult {
  id             String   @id @default(cuid())
  studentId      String
  classId        String
  academicYear   String
  annualAverage  Decimal  @db.Decimal(5,2)
  finalGrade     String
  annualPosition Int?
  passStatus     Boolean
  promoted       Boolean  @default(false)
  nextClassId    String?
  createdAt      DateTime @default(now())

  @@unique([studentId, academicYear])
  @@map("annual_results")
}

model ManebRecord {
  id            String        @id @default(cuid())
  studentId     String
  examType      ManebExamType
  candidateNo   String        @unique
  centerNo      String
  centerName    String
  academicYear  String
  subjectGrades Json
  overallGrade  String?
  status        ManebStatus   @default(REGISTERED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentId])
  @@map("maneb_records")
}

enum ManebExamType {
    JCE 
    MSCE
 }
enum ManebStatus   {
    REGISTERED
    SITTING
    RESULTS_RECEIVED 
    CERTIFIED
 }

// ─── HR MODULE ────────────────────────────────────────────

model StaffProfile {
  id                  String         @id @default(cuid())
  uid                 String         @unique   // Firebase Auth UID
  employeeNo          String         @unique
  firstName           String
  lastName            String
  email               String         @unique
  phone               String?
  role                String         // matches UserRole values
  department          String
  jobTitle            String
  employmentType      EmploymentType @default(FULL_TIME)
  status              StaffStatus    @default(ACTIVE)
  dateJoined          DateTime
  contractExpiry      DateTime?
  photoKey            String?        // Appwrite file ID
  salaryStructureId   String?
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]
  loans               StaffLoan[]
  performanceNotes    PerformanceNote[]
  borrowings          Borrowing[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([department])
  @@index([contractExpiry])
  @@map("staff_profiles")
}

enum EmploymentType { 
  FULL_TIME  
  PART_TIME  
  CONTRACT  
  TEMPORARY 
  }
enum StaffStatus    { 
  ACTIVE  
  ON_LEAVE  
  SUSPENDED  
  TERMINATED 
  }
model LeaveBalance {
  id          String      @id @default(cuid())
  staffId     String
  staff       StaffProfile @relation(fields: [staffId], references: [id])
  leaveType   LeaveType
  totalDays   Int         @default(0)
  usedDays    Int         @default(0)
  pendingDays Int         @default(0)
  year        Int         // calendar year

  @@unique([staffId, leaveType, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id           String       @id @default(cuid())
  staffId      String
  staff        StaffProfile @relation(fields: [staffId], references: [id])
  leaveType    LeaveType
  startDate    DateTime
  endDate      DateTime
  days         Int
  reason       String
  status       LeaveStatus  @default(PENDING)
  reviewedByUid String?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([staffId])
  @@index([status])
  @@map("leave_requests")
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  STUDY
  UNPAID
  EMERGENCY
}

enum LeaveStatus { 
  PENDING  
  APPROVED  
  REJECTED  
  CANCELLED 
  }

model StaffLoan {
  id              String       @id @default(cuid())
  staffId         String
  staff           StaffProfile @relation(fields: [staffId], references: [id])
  amount          Decimal      @db.Decimal(12,2)
  monthlyDeduction Decimal     @db.Decimal(10,2)
  totalRepaid     Decimal      @db.Decimal(12,2) @default(0)
  balance         Decimal      @db.Decimal(12,2)
  reason          String
  status          LoanStatus   @default(PENDING)
  approvedByUid   String?
  approvedAt      DateTime?
  disbursedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([staffId])
  @@map("staff_loans")
}

enum LoanStatus { 
  PENDING  
  APPROVED  
  DISBURSED  
  REPAYING  
  SETTLED  
  REJECTED 
  }

model PerformanceNote {
  id          String       @id @default(cuid())
  staffId     String
  staff       StaffProfile @relation(fields: [staffId], references: [id])
  academicYear String
  term        Int
  rating      Int          // 1–5
  notes       String
  authorUid   String
  createdAt   DateTime     @default(now())

  @@index([staffId, academicYear])
  @@map("performance_notes")
}

// ─── LIBRARY MODULE ───────────────────────────────────────

model Book {
  id            String       @id @default(cuid())
  title         String
  author        String
  isbn          String?      @unique
  category      BookCategory
  publisher     String?
  publishedYear Int?
  totalCopies   Int          @default(1)
  availableCopies Int        @default(1)
  barcode       String?      @unique
  coverKey      String?      // Appwrite file ID
  borrowings    Borrowing[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([category])
  @@index([title])
  @@map("books")
}

enum BookCategory {
  TEXTBOOK
  REFERENCE
  FICTION
  NONFICTION
  SCIENCE
  MATHEMATICS
  HUMANITIES
  PAST_PAPER
  OTHER
}

model Borrowing {
  id           String         @id @default(cuid())
  bookId       String
  book         Book           @relation(fields: [bookId], references: [id])
  borrowerType BorrowerType
  issuedByUid  String
  issuedAt     DateTime       @default(now())
  dueDate      DateTime
  returnedAt   DateTime?
  status       BorrowStatus   @default(ACTIVE)
  fineAmount   Decimal?       @db.Decimal(8,2)
  fineId       String?        // links to LibraryFine if created
  notes        String?
  studentId    String?
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staffId      String?
  staff        StaffProfile? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([studentId])
  @@index([staffId])
  @@index([status])
  @@index([dueDate])
  @@map("borrowings")
}

enum BorrowerType { 
  STUDENT
  STAFF 
  }

enum BorrowStatus { 
  ACTIVE  
  RETURNED  
  OVERDUE  
  LOST 
  }

model DigitalResource {
  id           String           @id @default(cuid())
  title        String
  type         DigitalResType
  subject      String?
  form         Int?             // 1–4, null = all forms
  academicYear String?          // for past papers
  fileKey      String           // Appwrite file ID
  fileSize     Int              // bytes
  mimeType     String           // application/pdf or application/epub+zip
  uploadedByUid String
  approved     Boolean          @default(false)
  approvedByUid String?
  approvedAt   DateTime?
  createdAt    DateTime         @default(now())

  @@index([type, approved])
  @@index([form, subject])
  @@map("digital_resources")
}

enum DigitalResType { 
  EBOOK
  PAST_PAPER
  REFERENCE
  STUDY_GUIDE
 }
